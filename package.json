{
  "name": "@root/elysia-ai",
  "version": "0.1.0",
  "packageManager": "yarn@4.1.0",
  "private": true,
  "author": "PinkElysiaDev",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "packages/@elysia-ai/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-tsconfig.js",
    "build": "turbo run build",
    "build:all": "yarn workspaces foreach -At run build",
    "publish:all": "yarn workspaces foreach -At --no-private npm publish --access public --tolerate-republish",
    "publish:dry": "yarn workspaces foreach -At --no-private pack --dry-run",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "check:source-hygiene": "node scripts/check-source-hygiene.cjs",
    "clean:artifacts": "node scripts/clean-generated-artifacts.cjs",
    "check:packages": "node scripts/check-packages.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PinkElysiaDev/elysia-ai.git"
  },
  "homepage": "https://github.com/PinkElysiaDev/elysia-ai",
  "bugs": {
    "url": "https://github.com/PinkElysiaDev/elysia-ai/issues"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "vitest": "^1.6.0"
  }
}
