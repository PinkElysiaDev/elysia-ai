{
  "name": "koishi-plugin-elysia-ai-observatory",
  "description": "Elysia A.I. observatory Koishi plugin.",
  "version": "0.1.0",
  "type": "module",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.cjs",
      "import": "./lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "node -e \"const fs=require('node:fs');fs.rmSync('lib',{recursive:true,force:true});fs.rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc -p tsconfig.json --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=lib/index.cjs --external:koishi --external:@elysia-ai/core --external:@elysia-ai/shared && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=lib/index.mjs --external:koishi --external:@elysia-ai/core --external:@elysia-ai/shared"
  },
  "dependencies": {
    "@elysia-ai/core": "workspace:*",
    "@elysia-ai/shared": "workspace:*"
  },
  "peerDependencies": {
    "koishi": "^4.18.0"
  },
  "devDependencies": {
    "@elysia-ai/observatory": "workspace:*",
    "esbuild": "^0.23.1",
    "koishi": "^4.18.0",
    "koishi-plugin-elysia-ai-runtime": "workspace:*",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "koishi",
    "koishi-plugin",
    "elysia-ai",
    "observatory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PinkElysiaDev/elysia-ai.git"
  },
  "homepage": "https://github.com/PinkElysiaDev/elysia-ai",
  "bugs": {
    "url": "https://github.com/PinkElysiaDev/elysia-ai/issues"
  },
  "author": "PinkElysiaDev",
  "koishi": {
    "description": "Elysia A.I. observatory Koishi plugin.",
    "service": {
      "implements": [
        "elysia.observatory"
      ]
    }
  },
  "license": "AGPL-3.0-or-later"
}
